# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_ALLOWED_USERS=123456789,987654321   # 你的 Telegram user ID，用逗号分隔

# IBKR Flex Query
# 在 IBKR Account Management → Reports → Flex Queries 里创建
IBKR_FLEX_TOKEN=your_flex_web_service_token
IBKR_FLEX_QUERY_ID=your_flex_query_id

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# xAI (Grok) — 用于实时新闻搜索（https://console.x.ai）
GROK_API_KEY=xai-...

# IBKR IB Gateway（Phase 4 — 实时账户/期权数据）
# Oracle Docker 部署默认让 FinanceBro 通过 Docker 内网连接 ib-gateway。
# paper 默认端口 4002，live 默认端口 4001。
COMPOSE_PROFILES=
IBKR_TWS_HOST=ib-gateway
IBKR_TWS_PORT=4002
IBKR_TWS_CLIENT_ID=10

# IB Gateway 容器（COMPOSE_PROFILES=ibkr 时启用）
TWS_USERID=
TWS_PASSWORD=
TRADING_MODE=paper
READ_ONLY_API=yes
TWOFA_TIMEOUT_ACTION=restart
AUTO_RESTART_TIME=03:45 AM
RELOGIN_AFTER_TWOFA_TIMEOUT=no
IB_GATEWAY_TIME_ZONE=America/New_York

# 仅用于每周人工 2FA/排障。务必用强密码；端口只绑定 Oracle 本机 127.0.0.1。
VNC_SERVER_PASSWORD=
