# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_ALLOWED_USERS=123456789,987654321   # 你的 Telegram user ID，用逗号分隔
TELEGRAM_ALLOW_ALL=false

# IBKR Flex Query
# 在 IBKR Account Management → Reports → Flex Queries 里创建
IBKR_FLEX_TOKEN=your_flex_web_service_token
IBKR_FLEX_QUERY_ID=your_flex_query_id

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# xAI (Grok) — 用于实时新闻搜索（https://console.x.ai）
GROK_API_KEY=xai-...

# Daily IBKR snapshot
DAILY_SNAPSHOT_ENABLED=false
DAILY_SNAPSHOT_USER_ID=123456789
DAILY_SNAPSHOT_TIME=07:00
DAILY_SNAPSHOT_TIMEZONE=Pacific/Auckland
DAILY_SNAPSHOT_NOTIFY=true

# Phase 6 proactive pushes
PROACTIVE_BRIEF_ENABLED=false
PROACTIVE_BRIEF_USER_ID=123456789
PROACTIVE_BRIEF_TIME=08:30
PROACTIVE_BRIEF_TIMEZONE=Pacific/Auckland

PROACTIVE_ALERT_ENABLED=false
PROACTIVE_ALERT_USER_ID=123456789
PROACTIVE_ALERT_TIME=08:35
PROACTIVE_ALERT_TIMEZONE=Pacific/Auckland
PROACTIVE_ALERT_PNL_PCT=-5
PROACTIVE_ALERT_POSITION_WEIGHT_PCT=35

# Uses Grok search; keep disabled unless you accept the polling cost.
PROACTIVE_NEWS_ENABLED=false
PROACTIVE_NEWS_USER_ID=123456789
PROACTIVE_NEWS_INTERVAL_MINUTES=180
